# ── Application ───────────────────────────────────────────────────
APP_NAME=Palato
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://api.palato.mv

# ── Database ───────────────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=palato
DB_USERNAME=palato
DB_PASSWORD=
DB_ROOT_PASSWORD=

# ── Redis ──────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# ── Queue ──────────────────────────────────────────────────────────
QUEUE_CONNECTION=redis
CACHE_DRIVER=redis
SESSION_DRIVER=redis

# ── Mail / Notifications ───────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=ops@palato.mv
MAIL_FROM_NAME="Palato Operations"

# ── WhatsApp (Vonage / Twilio) ─────────────────────────────────────
VONAGE_KEY=
VONAGE_SECRET=
VONAGE_WHATSAPP_NUMBER=

# ── File Storage (DO Spaces / S3) ──────────────────────────────────
FILESYSTEM_DISK=s3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=sgp1
AWS_BUCKET=palato-ops
AWS_ENDPOINT=https://sgp1.digitaloceanspaces.com
AWS_URL=https://palato-ops.sgp1.digitaloceanspaces.com

# ── Frontend ───────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://api.palato.mv
NEXT_PUBLIC_APP_NAME=Palato
